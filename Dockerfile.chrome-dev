# Deep-Live-Cam Chrome Extension Development Environment
FROM ubuntu:22.04

# Install Node.js and Chrome
RUN apt-get update && apt-get install -y \
    curl \
    git \
    python3 \
    python3-pip \
    nodejs \
    npm \
    chromium-browser \
    && rm -rf /var/lib/apt/lists/*

# Set up workspace
WORKDIR /workspace

# Copy project files
COPY . .

# Install Node dependencies
RUN npm install

# Default command
CMD ["/bin/bash"]
