# EditorConfig for Deep-Live-Cam Chrome

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.{html,css}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
